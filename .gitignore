# ============================================================================
# .gitignore — monorepo CoachRun (Angular front + Spring Boot back)
# Renommer ce fichier en ".gitignore" à la racine du nouveau dépôt.
# ============================================================================

# ── Secrets / environnement ────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── OS / éditeurs ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.iml

# ============================================================================
# BACKEND — Java / Maven / Spring Boot  (/back)
# ============================================================================
back/target/
back/.mvn/wrapper/maven-wrapper.jar
back/!**/src/main/**/target/
back/!**/src/test/**/target/
back/*.log
back/logs/
back/uploads/
back/HELP.md

# Compiled
*.class

# ============================================================================
# FRONTEND — Angular / Node  (/front)
# ============================================================================
front/node_modules/
front/dist/
front/.angular/
front/tmp/
front/out-tsc/
front/coverage/
front/.nx/
front/npm-debug.log*
front/yarn-error.log*
front/.env.local

# ── PWA / build artefacts ──────────────────────────────────────────────────
front/ngsw.json
front/*.tsbuildinfo

# ============================================================================
# DOCKER / DIVERS
# ============================================================================
*.local
docker-compose.override.yml
